@model List<Empleado>

<h1>Session Empleados</h1>

<a asp-controller="Empleados" asp-action="EmpleadosAlmacenados" class="btn btn-outline-primary">Ver Empleados Almacenados</a>
<h3>@ViewData["MENSAJE"]</h3>
<ul class="list-group">
    @foreach (Empleado empleado in Model)
    {
        <li class="list-group-item">
            @empleado.Apellido - 
            <a asp-controller="Empleados" asp-action="SessionEmpleados" asp-route-idempleado="@empleado.IdEmpleado" class="btn btn-outline-primary">
                Almacenar Empleado
            </a>
        </li>
    }
</ul>