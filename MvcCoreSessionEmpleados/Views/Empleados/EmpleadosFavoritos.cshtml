@{
    List<Empleado> favoritos = memoryCache.Get<List<Empleado>>("FAVORITOS");
}
<h1 style="color:blue">Empleados Favoritos</h1>
<p>
    <a
        asp-controller="Empleados"
        asp-action="SessionEmpleadosV5">
        Volver a Empleados V5
    </a>
</p>
<h2>@ViewData["MENSAJE"]</h2>
@if (favoritos == null)
{
    <h2 style="color:red">NO hay ningun empleado favorito</h2>
}
else
{
    <table class="table table-bordered table-warning">
        <thead></thead>
        <tr>
            <th>IdEmpleado</th>
            <th>Apellido</th>
            <th>Oficio</th>
            <th>Salario</th>
        </tr>
        <tbody>
            @foreach (Empleado empleado in favoritos)
            {
                <tr>
                    <td>@empleado.IdEmpleado</td>
                    <td>@empleado.Apellido</td>
                    <td>@empleado.Oficio</td>
                    <td>@empleado.Salario</td>
                </tr>
            }
        </tbody>
    </table>
}