@model List<Empleado>
<h1>Session Salarios Empleado</h1>
<h4>@ViewData["MENSAJE"]</h4>
<ul class="list-group">
    @foreach (Empleado empleado in Model)
    {
        <li class="list-group-item">
            @empleado.Apellido - 
            <a asp-controller="Empleados" asp-action="SessionSalarios" asp-route-salario="@empleado.Salario" class="btn btn-outline-primary">
                Almacenar Salario
            </a>
        </li>
    }
</ul>

<a asp-controller="Empleados" asp-action="SumaSalarial" class="btn btn-outline-secondary">
    Mostrar Suma Salarial
</a>
