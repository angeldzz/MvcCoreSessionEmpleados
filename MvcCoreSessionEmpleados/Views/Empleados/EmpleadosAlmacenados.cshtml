@{
    List<Empleado> empleados = Context.Session.GetObject<List<Empleado>>("EMPLEADOS");
}
@{
    ViewData["Title"] = "EmpleadosAlmacenados";
}

<h1>EmpleadosAlmacenados</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
@if (Context.Session.GetObject<List<Empleado>>("EMPLEADOS") != null)
{
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Apellido</th>
                <th>Oficio</th>
                <th>Salario</th>
                <th>Departamento</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in empleados)
            {
                <tr>
                    <td>@item.IdEmpleado</td>
                    <td>@item.Apellido</td>
                    <td>@item.Oficio</td>
                    <td>@item.Salario</td>
                    <td>@item.IdDepartamento</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.IdEmpleado">Edit</a> |
                        <a asp-action="Details" asp-route-id="@item.IdEmpleado">Details</a> |
                        <a asp-action="Delete" asp-route-id="@item.IdEmpleado">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <h2 style="color:red">No hay nada en session</h2>
}
