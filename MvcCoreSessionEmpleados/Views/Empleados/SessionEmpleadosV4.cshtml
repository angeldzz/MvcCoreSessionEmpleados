@model List<Empleado>

<h1 style="color:blue">Session Empleados IDS</h1>
<h3 style="color:green">@ViewData["MENSAJE"]</h3>

<a asp-controller="Empleados" asp-action="EmpleadosAlmacenadosV4" class="btn btn-outline-primary">Ver Empleados Almacenados</a>
<ul class="list-group ">
    @foreach (Empleado empleado in Model)
    {
        <li class="list-group-item list-group-item-primary">
            @empleado.Apellido -
            <a asp-controller="Empleados" asp-action="SessionEmpleadosV4" asp-route-idempleado="@empleado.IdEmpleado" class="btn btn-outline-primary">
                Almacenar ID Empleado
            </a>
        </li>
    }
</ul>