@model List<Empleado>
<h1>Empleados almacenados OK</h1>
<a asp-controller="Empleados" asp-action="SessionEmpleadosV5">Volver a empledos</a>

@if (Context.Session.GetString("IDSEMPLEADOS") == null)
{
    <h2 style="color:red">NO hay ningun empleado</h2>
}
else
{
    <table class="table table-bordered table-dark">
        <thead></thead>
        <tr>
            <th>IdEmpleado</th>
            <th>Apellido</th>
            <th>Oficio</th>
            <th>Salario</th>
            <th></th>
        </tr>
        <tbody>
            @foreach (Empleado empleado in Model)
            {
                <tr>
                    <td>@empleado.IdEmpleado</td>
                    <td>@empleado.Apellido</td>
                    <td>@empleado.Oficio</td>
                    <td>@empleado.Salario</td>
                    <td>
                        <a asp-controller="Empleados"
                           asp-action="EmpleadosAlmacenadosV5"
                           asp-route-ideliminar="@empleado.IdEmpleado"
                           class="btn btn-danger">
                            Eliminar empleado
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}